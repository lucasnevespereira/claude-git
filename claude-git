#!/usr/bin/env bash
set -euo pipefail

# claude-git — AI-powered git helpers using Claude CLI
# https://github.com/lucasnevespereira/claude-git

VERSION="0.1.0"
REPO="lucasnevespereira/claude-git"
CONFIG_FILE="$HOME/.claude-git"

# --- Config defaults ---

CLAUDE_GIT_MODEL="${CLAUDE_GIT_MODEL:-haiku}"
CLAUDE_GIT_MAX_LINES="${CLAUDE_GIT_MAX_LINES:-2000}"

# Load user config if exists
[[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE"

# --- Helpers ---

claude_pipe() {
  claude -p \
    --model "$CLAUDE_GIT_MODEL" \
    --output-format text \
    --no-session-persistence \
    --effort low \
    "$@"
}

has_changes() {
  ! git diff --quiet HEAD 2>/dev/null || ! git diff --cached --quiet 2>/dev/null
}

get_diff() {
  local diff
  diff=$(git diff HEAD 2>/dev/null)
  if [[ -z "$diff" ]]; then
    diff=$(git diff --cached 2>/dev/null)
  fi
  if [[ -z "$diff" ]]; then
    echo "No changes found." >&2
    return 1
  fi

  local total
  total=$(echo "$diff" | wc -l | tr -d ' ')
  if [[ "$total" -gt "$CLAUDE_GIT_MAX_LINES" ]]; then
    echo "(diff truncated: $total lines → $CLAUDE_GIT_MAX_LINES. adjust with: claude-git config max_lines <n>)" >&2
  fi

  echo "$diff" | head -n "$CLAUDE_GIT_MAX_LINES"
}

get_branch_diff() {
  local base="${1:-main}"
  local commits
  commits=$(git log "$base"..HEAD --oneline 2>/dev/null)
  if [[ -z "$commits" ]]; then
    echo "No commits ahead of $base." >&2
    return 1
  fi
  echo "=== Commits ==="
  echo "$commits"
  echo ""
  echo "=== Diff ==="
  git diff "$base"...HEAD | head -n "$CLAUDE_GIT_MAX_LINES"
}

# --- Commands ---

cmd_commit() {
  has_changes || { echo "No changes to commit."; return 1; }

  local msg
  msg=$(get_diff | claude_pipe "propose a conventional commit message for these changes. one line, max 72 chars. output only the message, nothing else.")

  [[ -z "$msg" ]] && { echo "Failed to generate message."; return 1; }

  echo ""
  echo "  $msg"
  echo ""

  if [[ "${1:-}" == "--yes" ]] || [[ "${1:-}" == "-y" ]]; then
    git add -A && git commit -m "$msg"
  else
    printf "Commit with this message? [y/N] "
    read -r confirm
    if [[ "$confirm" == "y" ]]; then
      git add -A && git commit -m "$msg"
    else
      echo "Aborted."
    fi
  fi
}

cmd_msg() {
  has_changes || { echo "No changes to commit."; return 1; }
  get_diff | claude_pipe "propose a conventional commit message for these changes. one line, max 72 chars. output only the message, nothing else."
}

cmd_review() {
  has_changes || { echo "No changes to review."; return 1; }
  get_diff | claude_pipe "review this diff. be concise. flag bugs, security issues, and logic errors. if it looks good, say so. skip style nitpicks."
}

cmd_pr() {
  local base="${1:-main}"
  get_branch_diff "$base" | claude_pipe "write a pull request description for these changes. format:

## What
one paragraph summary.

## Changes
- bullet points of key changes

output only the description, no title."
}

cmd_explain() {
  has_changes || { echo "No changes to explain."; return 1; }
  get_diff | claude_pipe "explain what these changes do in 2-3 sentences. be specific about the behavior change, not just what files were touched."
}

cmd_config() {
  local key="${1:-}"
  local value="${2:-}"

  # No args — show current config
  if [[ -z "$key" ]]; then
    echo "model     = $CLAUDE_GIT_MODEL"
    echo "max_lines = $CLAUDE_GIT_MAX_LINES"
    echo ""
    if [[ -f "$CONFIG_FILE" ]]; then
      echo "config: $CONFIG_FILE"
    else
      echo "config: (defaults, no config file)"
    fi
    return 0
  fi

  # One arg — show that key
  if [[ -z "$value" ]]; then
    case "$key" in
      model)     echo "$CLAUDE_GIT_MODEL" ;;
      max_lines) echo "$CLAUDE_GIT_MAX_LINES" ;;
      *)         echo "Unknown key: $key (available: model, max_lines)"; return 1 ;;
    esac
    return 0
  fi

  # Two args — set key=value
  local var_name
  case "$key" in
    model)     var_name="CLAUDE_GIT_MODEL" ;;
    max_lines) var_name="CLAUDE_GIT_MAX_LINES" ;;
    *)         echo "Unknown key: $key (available: model, max_lines)"; return 1 ;;
  esac

  # Update or create config file
  if [[ -f "$CONFIG_FILE" ]] && grep -q "^${var_name}=" "$CONFIG_FILE"; then
    sed -i '' "s/^${var_name}=.*/${var_name}=\"${value}\"/" "$CONFIG_FILE"
  else
    echo "${var_name}=\"${value}\"" >> "$CONFIG_FILE"
  fi

  echo "$key = $value"
}

cmd_upgrade() {
  echo "Checking for updates..."

  local latest
  latest=$(curl -fsSL "https://api.github.com/repos/${REPO}/releases/latest" 2>/dev/null | grep '"tag_name"' | cut -d'"' -f4)

  if [[ -z "$latest" ]]; then
    echo "Could not check for updates."
    return 1
  fi

  if [[ "v${VERSION}" == "$latest" ]]; then
    echo "Already on latest version (v${VERSION})."
    return 0
  fi

  echo "Updating v${VERSION} → ${latest}..."
  curl -fsSL "https://raw.githubusercontent.com/${REPO}/main/claude-git" -o "$HOME/.local/bin/claude-git"
  chmod +x "$HOME/.local/bin/claude-git"
  echo "Updated to ${latest}."
}

cmd_uninstall() {
  echo "Uninstalling claude-git..."

  rm -f "$HOME/.local/bin/claude-git"
  rm -f "$CONFIG_FILE"

  SHELL_RC="$HOME/.zshrc"
  [[ "$SHELL" == */bash ]] && SHELL_RC="$HOME/.bashrc"

  if [[ -f "$SHELL_RC" ]]; then
    sed -i '' '/claude-git aliases/d' "$SHELL_RC"
    sed -i '' '/# claude-git/d' "$SHELL_RC"
  fi

  echo "Removed. Restart your shell or run: source $SHELL_RC"
}

cmd_help() {
  cat <<EOF
claude-git v${VERSION} — AI-powered git helpers

Usage: claude-git <command> [options]

Commands:
  msg                 Propose a commit message (print only)
  commit [--yes|-y]   Propose + commit with confirmation (--yes to skip)
  review              Review staged/unstaged changes for bugs
  pr [base]           Generate PR description (default base: main)
  explain             Explain what the current changes do
  upgrade             Update to the latest version
  config              Show current config
  config <key>        Show a config value
  config <key> <val>  Set a config value
  uninstall           Remove claude-git from your system

Config keys:
  model               Claude model (default: haiku)
  max_lines           Max diff lines sent to Claude (default: 2000)

EOF
}

cmd_aliases() {
  cat <<'EOF'
# claude-git aliases
alias gpm='claude-git msg'
alias gac='claude-git commit'
alias gacf='claude-git commit --yes'
alias grev='claude-git review'
alias gpr='claude-git pr'
alias gex='claude-git explain'
EOF
}

# --- Main ---

case "${1:-help}" in
  msg)      cmd_msg ;;
  commit)   cmd_commit "${2:-}" ;;
  review)   cmd_review ;;
  pr)       cmd_pr "${2:-main}" ;;
  explain)  cmd_explain ;;
  config)   cmd_config "${2:-}" "${3:-}" ;;
  aliases)  cmd_aliases ;;
  upgrade)  cmd_upgrade ;;
  uninstall) cmd_uninstall ;;
  help|-h|--help) cmd_help ;;
  version|-v|--version) echo "claude-git v${VERSION}" ;;
  *)
    echo "Unknown command: $1"
    echo "Run 'claude-git help' for usage."
    return 1 2>/dev/null || exit 1
    ;;
esac
